{
  "name": "wmv-cycling-series",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "license": "MIT",
  "scripts": {
    "preinstall": "node check-node.js",
    "predev": "node check-node.js",
    "dev:server": "cd server && npm run dev",
    "dev:frontend": "vite",
    "dev:server:e2e": "cd server && PORT=3002 npm run dev",
    "dev:frontend:e2e": "VITE_PORT=5174 REACT_APP_BACKEND_URL=http://localhost:3002 vite",
    "dev": "concurrently -n \"backend,frontend\" -c \"blue,green\" \"npm:dev:server\" \"npm:dev:frontend\"",
    "dev:cleanup": "node scripts/dev-server.cjs cleanup",
    "clean": "rm -rf dist server/dist",
    "prebuild": "npm run clean",
    "build": "npm run build:server && npm run build:frontend",
    "build:frontend": "vite build",
    "build:server": "cd server && npm run build",
    "start:prod": "npm --prefix server start",
    "test": "npm run test:frontend && cd server && npm test",
    "test:frontend": "vitest run",
    "test:frontend:watch": "vitest",
    "test:watch": "cd server && npm run test:watch",
    "test:e2e": "ENV_FILE=e2e/.env.e2e playwright test --reporter=list",
    "test:e2e:headed": "ENV_FILE=e2e/.env.e2e playwright test --headed --reporter=list",
    "test:e2e:ui": "ENV_FILE=e2e/.env.e2e playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:auth": "ENV_FILE=e2e/.env.e2e playwright test --project=setup --headed",
    "lint:frontend": "eslint src",
    "lint:server": "npm --prefix server run lint",
    "lint": "npm run lint:frontend && npm run lint:server",
    "validate:docker": "bash scripts/validate-docker-build.sh",
    "audit": "npm audit --audit-level=high && cd server && npm audit --audit-level=high",
    "typecheck": "tsc -p tsconfig.json --noEmit && cd server && npm run typecheck",
    "webhook:emit": "tsx scripts/webhook-emitter.ts",
    "mock:strava": "cd mock-strava && npm run dev",
    "mock:strava:kill": "pkill -f 'cd mock-strava' || pkill -f 'mock-strava' || true",
    "db:fetch-prod": "bash scripts/fetch-prod-db.sh",
    "postinstall": "cd server && npm install",
    "prepare": "node scripts/install-hooks.cjs"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-query": "^5.99.0",
    "@tiptap/extension-character-count": "^3.22.3",
    "@tiptap/markdown": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^6.0.1",
    "baseline-browser-mapping": "^2.10.18",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
