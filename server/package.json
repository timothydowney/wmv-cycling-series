{
  "name": "wmv-backend",
  "private": true,
  "version": "0.1.0",
  "description": "Backend API for Western Mass Velo leaderboard app",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "preinstall": "node check-node.js",
    "start": "node dist/index.js",
    "build": "tsc",
    "predev": "node check-node.js",
    "dev": "NODE_ENV=development nodemon --exec tsx src/index.ts",
    "test": "NODE_ENV=test jest --coverage --runInBand",
    "test:watch": "NODE_ENV=test jest --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=high",
    "seed": "node scripts/seed.js",
    "export:season": "node scripts/export-season-data.js",
    "import:season": "node scripts/import-season-data.js",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:pg:bootstrap:schema": "node scripts/bootstrap-postgres-schema.js",
    "db:pg:migrate:from-sqlite": "node scripts/migrate-sqlite-to-postgres.js",
    "db:pg:verify:parity": "node scripts/verify-sqlite-postgres-parity.js"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "overrides": {
    "esbuild": "0.28.0",
    "protobufjs": "7.5.5",
    "follow-redirects": "1.16.0"
  },
  "dependencies": {
    "@google/genai": "^1.49.0",
    "@trpc/server": "^11.16.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "fuse.js": "^7.3.0",
    "pg": "^8.16.3",
    "strava-v3": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.17.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "better-sqlite3": "^12.8.0",
    "pg-mem": "^2.9.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
